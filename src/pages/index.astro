---
import { Image } from "astro:assets";
import DetailCard from "../components/DetailCard.astro";
import SectionIntro from "../components/SectionIntro.astro";
import WorkflowStepCard from "../components/WorkflowStepCard.astro";
import appHero from "../assets/app-2.png";
import appCta from "../assets/app.png";
import Layout from "../layouts/Layout.astro";

interface LinkItem {
  href: `#${string}`;
  label: string;
}

interface DetailCardItem {
  kicker: string;
  body: string;
  title?: string;
}

interface NumberedFeatureItem extends DetailCardItem {
  number: string;
}

interface WorkflowStepItem {
  step: string;
  title: string;
  body: string;
}

const navLinks: LinkItem[] = [
  { href: "#top", label: "Overview" },
  { href: "#features", label: "Outcomes" },
  { href: "#workflow", label: "Workflow" },
  { href: "#desktop", label: "Desktop" },
  { href: "#setup", label: "Setup" },
];

const heroSignals: DetailCardItem[] = [
  {
    kicker: "Signals",
    body: "Technical, semantic, and story cues stay visible when reviewing candidate moments.",
  },
  {
    kicker: "State",
    body: "Runtime readiness and optional assets are separated so recovery stays legible.",
  },
  {
    kicker: "Export",
    body: "The current review state is shaped for an editorial handoff instead of a demo-only flow.",
  },
];

const overviewCards: DetailCardItem[] = [
  {
    kicker: "Process",
    title: "4 focused phases",
    body: "Media discovery, per-asset analysis, take selection, and timeline assembly turn raw footage into a usable shortlist.",
  },
  {
    kicker: "Runtime",
    title: "Packaged desktop stack",
    body: "The packaged app bundles Python, analyzer resources, and media tools so the core workflow stays local.",
  },
  {
    kicker: "Output",
    title: "Editor stays in control",
    body: "Review shortlisted segments, promote a best take per clip, and export the active timeline into DaVinci Resolve.",
  },
];

const proofCards: DetailCardItem[] = [
  {
    kicker: "Transcript-aware",
    title: "Speech support stays local when transcript runtime is available",
    body: "Local transcript extraction can inform segment refinement, speech-aware scoring, and review without turning the workflow into a cloud dependency.",
  },
  {
    kicker: "Review provenance",
    title: "Segments stay explainable inside the desktop review surface",
    body: "The app preserves how a segment was formed, what signals supported it, and which take is currently active in the assembled timeline.",
  },
  {
    kicker: "Graceful fallback",
    title: "Optional AI paths can degrade without killing the workflow",
    body: "Deterministic analysis still runs when optional assets are unavailable, and the packaged app can step down transcript, CLIP, or local-VLM features as needed.",
  },
];

const featureCards: NumberedFeatureItem[] = [
  {
    number: "01",
    title: "Screen large footage sets locally",
    body: "Media discovery, proxy matching, frame sampling, audio analysis, and seed-region building all happen on your machine.",
    kicker: "Local screening",
  },
  {
    number: "02",
    title: "Grade and compare candidate moments",
    body: "Deterministic scoring, optional local AI analysis, and review provenance make it easier to understand why one segment is worth keeping over another.",
    kicker: "Review signals",
  },
  {
    number: "03",
    title: "Assemble a first-pass rough timeline",
    body: "The result is not a finished edit. It is a stronger starting point with shortlisted shots, best-take control, and a Resolve-oriented export path.",
    kicker: "Editorial handoff",
  },
];

const workflowSteps: WorkflowStepItem[] = [
  {
    step: "1",
    title: "Media discovery",
    body: "Select a media folder, discover supported video files, and match sources to proxies before deeper analysis begins.",
  },
  {
    step: "2",
    title: "Per-asset analysis",
    body: "Extract frame and audio signals, build seed regions, refine segment boundaries, and apply transcript-backed or local-AI analysis when available.",
  },
  {
    step: "3",
    title: "Take selection",
    body: "Score the candidate segments, narrow them to the strongest takes per asset, and preserve the reasoning behind each recommendation.",
  },
  {
    step: "4",
    title: "Timeline assembly",
    body: "Preview the assembled timeline, promote or clear the best take for each clip, and export the active review state into Resolve via FCPXML.",
  },
];

const desktopCards: DetailCardItem[] = [
  {
    kicker: "Best-take control",
    body: "The desktop review flow persists best-take overrides per clip so the exported timeline reflects the editor’s current decisions instead of a fixed auto-pick.",
  },
  {
    kicker: "Resolve handoff",
    body: "Export writes an FCPXML timeline that follows the active desktop review state so the next step can happen inside DaVinci Resolve, not in the browser.",
  },
  {
    kicker: "Packaged mode",
    body: "Bundled runtime resources and app-managed storage let packaged builds keep processing without a checked-out repository.",
  },
  {
    kicker: "Graceful fallback",
    body: "Optional transcript, CLIP, or local-VLM paths can step down when assets are missing so startup and review do not dead-end.",
  },
];

const setupCards: DetailCardItem[] = [
  {
    kicker: "In the app",
    body: "Choose a media folder, click Process, review shortlisted shots and grades, and export the active desktop timeline.",
  },
  {
    kicker: "Export",
    body: "The export action rebuilds the timeline from the current review state and writes an FCPXML file for DaVinci Resolve.",
  },
  {
    kicker: "Repository workflow",
    body: "The checked-out repo path is useful for development and testing, while packaged builds preserve the same core review model with app-managed resources and outputs.",
  },
];

const quickStartCommands = [
  "git clone https://github.com/Mallfurion/roughcut-stdio.git",
  "cd roughcut-stdio",
  "npm run setup",
  "npm run view",
].join("\n");
---

<Layout
  title="Roughcut Stdio | Local-First Review Workflow for Editors"
  description="Roughcut Stdio is a local-first macOS desktop app that screens footage, surfaces strong candidate moments, and assembles a first-pass rough timeline for editorial review."
>
  <header class="pointer-events-none fixed inset-x-0 top-4 z-50">
    <div class="page-shell">
      <div
        class="glass-panel pointer-events-auto flex flex-col gap-4 rounded-[28px] px-4 py-4 md:flex-row md:items-center md:justify-between md:px-5"
      >
        <a
          class="flex w-fit items-center gap-3"
          href="#top"
          aria-label="Roughcut Stdio home"
        >
          <img
            src="/logo.svg"
            alt=""
            class="h-10 w-10 rounded-xl"
            width="1024"
            height="1024"
          />
          <span class="text-rough-text text-base font-bold tracking-[0.02em]">
            Roughcut Stdio
          </span>
        </a>
        <nav
          class="text-rough-muted flex flex-wrap items-center gap-x-4 gap-y-2 text-sm"
          aria-label="Primary"
        >
          {
            navLinks.map(({ href, label }) => (
              <a class="nav-link" href={href}>
                {label}
              </a>
            ))
          }
          <a
            class="nav-link inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/8 bg-white/[0.03]"
            href="https://github.com/Mallfurion/roughcut-stdio"
            target="_blank"
            rel="noreferrer"
            aria-label="Open Roughcut Stdio repository on GitHub"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              class="h-4.5 w-4.5 fill-current"
            >
              <path
                d="M12 1.5a10.5 10.5 0 0 0-3.32 20.46c.53.1.72-.23.72-.5v-1.94c-2.96.64-3.58-1.26-3.58-1.26-.48-1.2-1.17-1.52-1.17-1.52-.96-.66.07-.65.07-.65 1.05.08 1.6 1.07 1.6 1.07.94 1.58 2.46 1.13 3.06.86.1-.67.37-1.13.67-1.39-2.36-.27-4.84-1.16-4.84-5.18 0-1.14.42-2.07 1.1-2.8-.1-.27-.48-1.35.1-2.8 0 0 .9-.28 2.95 1.07a10.37 10.37 0 0 1 5.38 0c2.04-1.35 2.94-1.07 2.94-1.07.59 1.45.22 2.53.11 2.8.69.73 1.1 1.66 1.1 2.8 0 4.03-2.48 4.9-4.85 5.17.38.32.72.94.72 1.91v2.83c0 .28.19.61.73.5A10.5 10.5 0 0 0 12 1.5Z"
              ></path>
            </svg>
          </a>
        </nav>
      </div>
    </div>
  </header>

  <main id="main-content" class="page-shell space-y-6 pt-28 pb-24 md:pt-32">
    <section
      id="top"
      class="section-anchor grid gap-8 py-8 lg:grid-cols-[0.88fr_minmax(0,1.12fr)] lg:items-center lg:gap-10 xl:gap-12"
    >
      <div class="space-y-7 lg:pt-4">
        <div class="reveal">
          <p class="eyebrow">Footage screening for editors</p>
          <h1
            class="text-rough-text mt-3 max-w-[11ch] text-[clamp(2.9rem,6.8vw,5.2rem)] leading-[0.94] font-extrabold tracking-[-0.045em]"
          >
            Find the parts of the footage worth your time.
          </h1>
          <p class="lead mt-5 max-w-[60ch]">
            Roughcut Stdio is a <b>macOS desktop app</b> that scans large media sets
            locally, refines candidate segments, grades the strongest moments, and
            assembles a first-pass rough timeline so editors do not have to scrub
            every clip from start to finish.
          </p>
          <div class="mt-7 flex flex-wrap gap-3.5">
            <a class="button-base button-primary" href="#workflow">
              See the Workflow
            </a>
            <a class="button-base button-secondary" href="#setup">
              See Quick Start
            </a>
          </div>
          <ul class="mt-7 flex flex-wrap gap-2.5" aria-label="Product signals">
            <li class="chip">macOS desktop app</li>
            <li class="chip">Local-first analysis</li>
            <li class="chip">Resolve-ready FCPXML export</li>
          </ul>
        </div>
      </div>

      <div class="reveal relative">
        <div class="halo halo--mint"></div>
        <div class="halo halo--gold"></div>

        <div class="relative ml-auto max-w-[760px]" data-tilt-card>
          <div class="visual-card glass-panel overflow-hidden rounded-[30px]">
            <div
              class="flex items-center justify-between gap-2 border-b border-white/5 px-4 py-3"
            >
              <div class="flex gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
              </div>
              <span
                class="text-rough-muted text-[0.7rem] font-semibold tracking-[0.18em] uppercase"
              >
                Review Surface
              </span>
            </div>
            <Image
              src={appHero}
              alt="Roughcut Stdio desktop review interface showing selected footage, graded sections, and export controls"
              class="w-full rounded-b-[30px]"
              format="webp"
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <div
            class="floating-note absolute top-[84px] -right-3 z-10 hidden w-[232px] lg:block"
          >
            <strong>Review-first</strong>
            <span>
              Best takes, grades, provenance, and export status in one surface.
            </span>
          </div>

          <div
            class="floating-note absolute bottom-[78px] -left-5 z-10 hidden w-[220px] sm:block lg:block"
          >
            <strong>4-phase pipeline</strong>
            <span>
              Discover, analyze, select, and assemble without hiding the
              context.
            </span>
          </div>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          {
            heroSignals.map(({ kicker, body }) => (
              <DetailCard
                kicker={kicker}
                body={body}
                cardClass="rounded-[18px] p-4"
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="grid gap-4 md:grid-cols-3">
      {
        overviewCards.map(({ kicker, title, body }) => (
          <DetailCard
            kicker={kicker}
            title={title}
            body={body}
            cardClass="reveal p-5"
            bodyClass="leading-6"
          />
        ))
      }
    </section>

    <section
      id="proof"
      class="section-anchor grid gap-4 pt-2 xl:grid-cols-[0.88fr_minmax(0,1.12fr)] xl:items-start"
    >
      <SectionIntro
        eyebrow="Built for the real bottleneck"
        title="The job is to reduce viewing burden, not replace editing."
        body="Roughcut Stdio exists for the point in post-production where there is too much footage to watch manually. It narrows the search space, surfaces likely keeps, and makes the first rough selection inspectable enough that the editor can decide what actually deserves time."
        wrapperClass="max-w-3xl"
      />

      <div class="grid gap-4 md:grid-cols-3 xl:grid-cols-1">
        {
          proofCards.map(({ kicker, title, body }) => (
            <DetailCard
              kicker={kicker}
              title={title}
              body={body}
              cardClass="reveal"
            />
          ))
        }
      </div>
    </section>

    <section id="features" class="section-anchor pt-2">
      <SectionIntro
        eyebrow="What the tool actually does"
        title="Three ways Roughcut Stdio helps before the real edit starts."
        wrapperClass="mb-6 max-w-3xl"
      />
      <div class="grid gap-4 lg:grid-cols-3">
        {
          featureCards.map(({ number, title, body }) => (
            <article class="reveal glass-panel rounded-[22px] p-6">
              <span class="text-rough-warn text-sm font-bold tracking-[0.18em]">
                {number}
              </span>
              <h3 class="text-rough-text mt-5 text-[1.32rem] font-bold">
                {title}
              </h3>
              <p class="text-rough-muted mt-2 leading-7">{body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="workflow" class="section-anchor pt-2">
      <SectionIntro
        eyebrow="How it flows"
        title="One path from footage folder to editorial review."
        wrapperClass="mb-6 max-w-3xl"
      />
      <div class="grid gap-4 md:grid-cols-2">
        {
          workflowSteps.map(({ step, title, body }) => (
            <WorkflowStepCard step={step} title={title} body={body} />
          ))
        }
      </div>
    </section>

    <section id="desktop" class="section-anchor pt-2">
      <div
        class="grid gap-4 lg:grid-cols-[1.02fr_minmax(0,0.98fr)] lg:items-start"
      >
        <article class="reveal glass-panel rounded-[28px] p-7">
          <p class="eyebrow">Inside the desktop app</p>
          <h2 class="section-heading mt-3 max-w-[14ch]">
            The review surface is built for selection, not spectacle.
          </h2>
          <p class="text-rough-muted mt-5 leading-7">
            Roughcut Stdio shows shortlisted segments, transcript excerpts when
            available, grading signals, segment provenance, and the assembled
            timeline preview in one place so the editor can refine the first
            pass instead of reverse-engineering it. The packaged desktop runtime
            can carry Python, analyzer resources, <code>ffmpeg</code>, and
            <code>ffprobe</code> so the core workflow stays local.
          </p>
          <div class="mt-7 flex flex-wrap gap-3.5">
            <a class="button-base button-primary" href="#setup">
              Open Setup Steps
            </a>
            <a class="button-base button-secondary" href="#workflow">
              Review the Workflow
            </a>
          </div>
        </article>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            desktopCards.map(({ kicker, body }) => (
              <DetailCard kicker={kicker} body={body} cardClass="reveal" />
            ))
          }
        </div>
      </div>
    </section>

    <section id="setup" class="section-anchor pt-2">
      <div
        class="grid gap-4 lg:grid-cols-[0.9fr_minmax(0,1.1fr)] lg:items-stretch"
      >
        <article class="reveal glass-panel h-full rounded-[28px] p-7">
          <p class="eyebrow">Quick start</p>
          <h2 class="section-heading mt-3">
            Get from clone to desktop review fast.
          </h2>
          <p class="text-rough-muted mt-5 leading-7">
            On macOS, the repository workflow starts with setup and then
            launches the desktop app. From there the tool becomes an
            editor-facing review flow: choose footage, process it, inspect the
            shortlisted takes, and export the current timeline state.
          </p>
          <div
            class="mt-6 rounded-[22px] border border-white/8 bg-black/20 p-5"
          >
            <pre
              class="text-rough-text overflow-x-auto text-sm leading-7"><code>{quickStartCommands}</code></pre>
          </div>
        </article>

        <div class="grid gap-4 sm:auto-rows-fr sm:grid-cols-2">
          {
            setupCards.map(({ kicker, body }, index) => (
              <DetailCard
                kicker={kicker}
                body={body}
                cardClass={
                  index === 2 ? "reveal h-full sm:col-span-2" : "reveal h-full"
                }
              />
            ))
          }
          <article
            class="beta-card reveal glass-panel relative h-full overflow-hidden rounded-[22px] p-6 sm:col-span-2"
          >
            <div class="beta-card__orb" aria-hidden="true"></div>
            <div class="beta-card__grid relative gap-5">
              <div>
                <span class="detail-kicker">Desktop beta</span>
                <h3
                  class="text-rough-text max-w-[14ch] text-[clamp(1.6rem,3vw,2.4rem)] leading-[0.94] font-extrabold tracking-[-0.045em]"
                >
                  Standalone desktop app now in
                  <span class="text-rough-warn">Beta</span>.
                </h3>
                <p
                  class="text-rough-muted mt-3 max-w-[34ch] text-base leading-7"
                >
                  Stable release coming soon.
                </p>
              </div>
              <div
                class="beta-card__status"
                aria-label="Current desktop release status"
              >
                <span class="beta-card__dot" aria-hidden="true"></span>
                <span>Beta live</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="cta" class="section-anchor reveal pt-2">
      <div
        class="glass-panel relative overflow-hidden rounded-[30px] px-7 py-10 md:px-10"
      >
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(95,209,166,0.2),transparent_32%),radial-gradient(circle_at_bottom_left,rgba(255,202,107,0.14),transparent_24%)]"
        >
        </div>
        <div
          class="relative grid gap-x-10 gap-y-5 lg:grid-cols-[60%_35%] lg:grid-rows-[auto_auto] lg:items-start"
        >
          <div class="space-y-6 lg:col-start-1 lg:row-start-1">
            <p class="eyebrow">Next step</p>
            <h2 class="section-heading mt-3 max-w-4xl lg:text-5xl xl:text-7xl">
              Start with a media folder. Leave with a rough cut you can keep
              editing.
            </h2>
          </div>

          <div
            class="glass-panel flex h-full flex-col justify-center overflow-hidden rounded-[24px] border-white/8 bg-black/10 shadow-[0_24px_80px_rgba(0,0,0,0.26)] lg:col-start-2 lg:row-start-1 lg:self-start"
          >
            <Image
              src={appCta}
              alt="Roughcut Stdio desktop app showing the review surface and assembled timeline"
              class="w-full object-cover object-left-top"
              format="webp"
            />
          </div>

          <p
            class="lead max-w-3xl lg:col-start-1 lg:row-start-2 lg:self-center"
          >
            Everything on this page is aimed at the actual handoff: how Roughcut
            Stdio screens footage, behaves as a desktop runtime, and gets you to
            a Resolve-ready rough cut faster.
          </p>

          <div
            class="grid grid-cols-2 gap-3.5 lg:col-start-2 lg:row-start-2 lg:self-center"
          >
            <a
              class="button-base button-primary w-full px-5 text-center leading-tight"
              href="#setup"
            >
              Open Setup
            </a>
            <a
              class="button-base button-secondary w-full px-5 text-center leading-tight"
              href="#desktop"
            >
              Desktop Runtime
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
